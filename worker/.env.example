# Creator video worker environment.
# All server-side secrets — never expose these to the web app or a browser.

# Supabase (same project as the web app)
SUPABASE_URL=https://your-project-ref.supabase.co
# Settings → API → service_role key. SECRET. Bypasses RLS — worker only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare R2 (same bucket as the web app)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-private-bucket-name

# Optional tuning
# WORKER_NAME=creator-worker
# WORKER_LEASE_SECONDS=300
# WORKER_POLL_INTERVAL_MS=4000
# WORKER_PROXY_HEIGHT=720
