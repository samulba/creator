# Creator video worker environment.
# All server-side secrets — never expose these to the web app or a browser.

# Supabase (same project as the web app)
SUPABASE_URL=https://your-project-ref.supabase.co
# Settings → API → service_role key. SECRET. Bypasses RLS — worker only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare R2 (same bucket as the web app)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-private-bucket-name

# Gemini analysis + story + script (Phases 5–6). SECRET — server-side only.
# Without GEMINI_API_KEY the worker skips coarse_analysis / story_generation /
# script_generation: the pipeline pauses at "understanding_gameplay" instead of
# failing. Get a key from Google AI Studio (https://aistudio.google.com/apikey).
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs narration (Phase 7). SECRET — server-side only.
# Without ELEVENLABS_API_KEY the worker skips voice_generation: the pipeline
# pauses at "generating_voice". The default model is a PINNED id (never
# "latest"); the per-character model comes from the character's
# voice_settings.model_id when set. Get a key from https://elevenlabs.io.
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional tuning
# WORKER_NAME=creator-worker
# WORKER_LEASE_SECONDS=300
# WORKER_POLL_INTERVAL_MS=4000
# WORKER_PROXY_HEIGHT=720
# GEMINI_FILE_TIMEOUT_MS=300000
# GEMINI_REQUEST_TIMEOUT_MS=600000
# ELEVENLABS_REQUEST_TIMEOUT_MS=300000
