# Creator environment variables
# Copy this file to .env.local for local development and fill in values from
# your Supabase project (Project Settings → API).
#
# Only public, RLS-bound values belong here. Never add the service-role key,
# a secret key, or the database password to any NEXT_PUBLIC_ variable.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Canonical public API key. Newer Supabase projects expose this as the
# "publishable" key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Legacy fallback for older Supabase projects that only have an anon key.
# Set either this or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY — not both.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
