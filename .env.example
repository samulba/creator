# Creator environment variables
# Copy this file to .env.local for local development.
#
# Only public, RLS-bound values may use the NEXT_PUBLIC_ prefix. Never put
# the Supabase service-role key, a secret key, or the database password in
# any NEXT_PUBLIC_ variable.

# ── Supabase (Project Settings → API) ─────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Canonical public API key. Newer Supabase projects expose this as the
# "publishable" key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Legacy fallback for older Supabase projects that only have an anon key.
# Set either this or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY — not both.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Cloudflare R2 (server-only — no NEXT_PUBLIC_ prefix, ever) ────────────
# R2 dashboard → Manage API tokens → Object Read & Write for the bucket.
# The bucket must stay private and needs a CORS rule for browser uploads:
#   AllowedOrigins: your app origin(s)
#   AllowedMethods: PUT, GET
#   AllowedHeaders: content-type
#   ExposeHeaders: ETag

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-private-bucket-name
